{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpticalTable",
  "version": "0.22.0",
  "identifier": "com.dlmarks.opticaltable",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Optical Table",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "url": "optical_table_22.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
